<?xml version="1.0" encoding="utf-8"?>
<!--
    Alert list item row.

    Redesigned (v1.5.2):
    - Removed the "截图" chip and the expandable details section per
      product feedback. Snapshot viewing is still available by tapping
      the thumbnail (click handler in AlertListAdapter invokes
      onSnapshotClick when the alert has a snapshot).
    - "录像" chip renamed to "查看录像" and given a wider minTouch
      target so the label is fully visible on the dashboard's narrow
      recent-alerts list.
    - Removed the chevron expand button — no more dropdown.
    - Removed the bottom metadata block (event_id / frame_time /
      zones / camera-full / jump-to-camera button). The row is now a
      single, fixed-height line: thumbnail + label/confidence/camera +
      "查看录像" button. The camera name (e.g. "前门") gets the full
      remaining width and is no longer truncated.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="72dp">

    <!-- Thumbnail (tap to open full-resolution snapshot modal) -->
    <FrameLayout
        android:id="@+id/thumbnailContainer"
        android:layout_width="72dp"
        android:layout_height="48dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/camera_bg" />

        <ProgressBar
            android:id="@+id/progressThumbnail"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@android:color/white" />

        <!-- Play overlay: only shown when the alert has a clip
             (chipClip visibility tracks hasClip). Tapping the
             thumbnail still opens the snapshot modal; the play badge
             is just a visual hint that a clip is also available. -->
        <ImageView
            android:id="@+id/btnPlay"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_play_circle"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Main content: label + confidence + camera name. Weight=1 so
         it takes all available width and the camera name (e.g. "前门")
         is never truncated by the "查看录像" button on the right. -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <!-- Top row: detection label + confidence chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/error"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.chip.Chip
                android:id="@+id/tvConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                app:chipBackgroundColor="@color/primary"
                app:chipCornerRadius="4dp"
                app:chipStrokeWidth="0dp"
                app:closeIconVisible="false"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Second row: timestamp (compact) -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="3dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Third row: camera name + zones. Full width so "前门" and
             similar short names are never clipped by the action button. -->
        <TextView
            android:id="@+id/tvCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvZones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- "查看录像" button: tap to jump to the camera's recordings.
         Replaces the old "录像" chip. Wider minTouch target so the
         text is always fully visible. -->
    <com.google.android.material.chip.Chip
        android:id="@+id/chipClip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/badge_clip"
        android:textSize="11sp"
        android:textColor="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        app:chipBackgroundColor="@color/online"
        app:chipCornerRadius="6dp"
        app:chipStrokeWidth="0dp"
        app:closeIconVisible="false"
        app:chipMinHeight="32dp"
        android:visibility="gone" />

</LinearLayout>
