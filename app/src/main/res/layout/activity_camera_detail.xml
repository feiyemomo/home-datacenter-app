<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top app bar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/card_bg"
            android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
            app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
            app:title="@string/camera_detail_title"
            app:titleTextColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Camera header card: name / status / vendor -->
            <LinearLayout
                android:id="@+id/cardHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvCameraName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvCameraMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvCameraStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="12sp"
                    android:textColor="@color/online" />
            </LinearLayout>

            <!-- PTZ section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_ptz_section"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/cardPtz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvPtzUnsupported"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_ptz_unsupported"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:visibility="gone" />

                <!-- D-pad: 3x3 grid -->
                <GridLayout
                    android:id="@+id/ptzGrid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:columnCount="3"
                    android:rowCount="3"
                    android:useDefaultMargins="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzUpLeft"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:visibility="invisible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzUp"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:icon="@drawable/ic_ptz_up"
                        app:iconTint="@color/text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzUpRight"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:visibility="invisible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzLeft"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:icon="@drawable/ic_ptz_left"
                        app:iconTint="@color/text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzStop"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:icon="@drawable/ic_ptz_stop"
                        app:iconTint="@color/error" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzRight"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:icon="@drawable/ic_ptz_right"
                        app:iconTint="@color/text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzDownLeft"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:visibility="invisible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzDown"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:icon="@drawable/ic_ptz_down"
                        app:iconTint="@color/text_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPtzDownRight"
                        style="@style/Widget.Material3.Button.IconButton.Outlined"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:visibility="invisible" />
                </GridLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/camera_ptz_speed"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <SeekBar
                        android:id="@+id/seekPtzSpeed"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:max="100"
                        android:progress="50" />

                    <TextView
                        android:id="@+id/tvPtzSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.50"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Presets section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_presets_section"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPresets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvPresetsEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_presets_empty"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddPreset"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/camera_preset_add"
                    app:icon="@drawable/ic_add" />
            </LinearLayout>

            <!-- Settings section: audio / recording / codec / delete -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/camera_settings_section"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAudio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_audio_enable"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="56dp"
                    android:layout_marginTop="-2dp"
                    android:text="@string/camera_audio_summary"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchRecording"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_recording_enable"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="56dp"
                    android:layout_marginTop="-2dp"
                    android:text="@string/camera_recording_summary"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCodecH264"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/camera_codec_h264" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/camera_delete"
                    android:textColor="@color/error"
                    app:strokeColor="@color/error" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
