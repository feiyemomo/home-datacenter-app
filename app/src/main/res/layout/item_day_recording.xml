<?xml version="1.0" encoding="utf-8"?>
<!--
    v1.6.2: per-day recording card. Replaces the v1.5.x per-clip
    item_recording.xml as the default entry view when the user taps
    "查看录像". Each card represents one LOCAL day and shows:
      - Day-of-month (large) + month/year (small) on the left
      - Weekday + recording count + total duration in the middle
      - Status chip on the right: warm peach pill with total duration

    Tapping the card launches playDayAsPlaylist for that date.

    v1.6.8: redesigned to match the warm liquid glass theme:
      - Card background uses bg_glass_card_warm (frosted cream tile
        with warm peach border) instead of plain white bg_card_rounded
      - Left accent stripe in warm peach primary color gives each
        card a "tagged" look and reinforces the warm palette
      - Larger date typography (32sp → 34sp) + tighter month/year
        kerning for stronger visual hierarchy
      - Status chip switches from green-only to context-aware:
        warm peach when recordings exist (matches the accent stripe),
        keeping the green variant for explicit "today" highlight
      - Removed the rotated chevron (visual noise); the entire card
        is tappable so the affordance is implicit
      - Added 2dp elevation for a floating tile effect that pairs
        with the liquid glass background
      - Added "今天" badge (gone by default; shown for today's date
        from DayRecordingAdapter.bind) above the date block to give
        the user an immediate visual anchor for the current day
      - Added a small play hint icon at the right edge of the stats
        row to reinforce the tap affordance
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:elevation="2dp"
        android:background="@drawable/bg_glass_card_warm">

        <!-- Left accent stripe: warm peach, 3dp wide, full height of
             the card. Visually "tags" each card with the app's
             primary color, reinforcing the warm liquid glass theme. -->
        <View
            android:layout_width="3dp"
            android:layout_height="42dp"
            android:background="@color/primary"
            android:layout_marginEnd="10dp" />

        <!-- Date block: large day-of-month + small month/year +
             optional "今天" badge -->
        <LinearLayout
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- v1.6.8: "今天" badge — shown only for the current
                 LOCAL day. Small peach-tinted pill above the date
                 number gives the user an instant visual anchor. -->
            <TextView
                android:id="@+id/tvTodayBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今天"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_button_primary"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:layout_marginBottom="3dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDayOfMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/tvMonthYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.04"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:background="@color/divider"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="12dp" />

        <!-- Middle: weekday + recording stats + play hint -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWeekday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Status chip + play hint icon. v1.6.8: chip now shows
             total duration (e.g. "5h 12m") instead of duplicating
             the segment count already shown in tvStats. The small
             play icon below the chip reinforces "tap to play" and
             pairs visually with the warm peach accent stripe. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:textColor="@android:color/white" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="6dp"
                android:src="@drawable/ic_video"
                android:alpha="0.55"
                android:contentDescription="play"
                app:tint="@color/primary" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
