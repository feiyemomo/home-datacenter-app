<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="100dp">

            <!-- Greeting + system status banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_greeting"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <!-- Compact system status banner: green/yellow/red pill -->
                <LinearLayout
                    android:id="@+id/statusBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_status_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <View
                        android:id="@+id/statusBannerDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_offline" />

                    <TextView
                        android:id="@+id/statusBannerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="6dp"
                        android:text="@string/loading" />
                </LinearLayout>
            </LinearLayout>

            <!-- Live detection alert banner (auto-dismiss after 8s) -->
            <LinearLayout
                android:id="@+id/liveAlertBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_rounded"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_alerts"
                    android:contentDescription="alert"
                    android:layout_marginEnd="10dp"
                    app:tint="@color/accent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvLiveAlertLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvLiveAlertConfidence"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLiveAlertCamera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="实时"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint" />

            </LinearLayout>

            <!-- Weather card (compact: includes inline progress/error) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/weatherCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvWeatherLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical|bottom">

                            <TextView
                                android:id="@+id/tvWeatherTemp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="40sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tvWeatherDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginStart="10dp"
                                android:layout_marginBottom="6dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvWeatherExtra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivWeatherIcon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="weather icon" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressWeather"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/primary" />

                <TextView
                    android:id="@+id/tvWeatherError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- System status grid (4 cards: Devices, MQTT, WS Clients, Uptime) -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                app:orientation="horizontal"
                android:layout_marginTop="10dp">

                <!-- v1.5.4: include layout_height MUST be "120dp" (not
                 wrap_content) — otherwise it overrides item_stat_card.xml's
                 root FrameLayout height=120dp and the fixed-height
                 grid alignment breaks (uptime string gets clipped). -->
            <include layout="@layout/item_stat_card"
                android:id="@+id/cardDevices"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="6dp" />

            <include layout="@layout/item_stat_card"
                android:id="@+id/cardMqtt"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="6dp" />

            <include layout="@layout/item_stat_card"
                android:id="@+id/cardWs"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="6dp" />

            <include layout="@layout/item_stat_card"
                android:id="@+id/cardUptime"
                android:layout_width="0dp"
                android:layout_height="120dp"
                app:layout_columnWeight="1"
                app:layout_gravity="fill_horizontal"
                android:layout_marginStart="6dp"
                android:layout_marginTop="6dp" />

            </androidx.gridlayout.widget.GridLayout>

            <!-- Network quality card (immediately under stat grid) -->
            <LinearLayout
                android:id="@+id/cardNetwork"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="14dp"
                android:layout_marginTop="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/network_quality"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:textAllCaps="true" />

                    <LinearLayout
                        android:id="@+id/starsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView android:id="@+id/star1" android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_off" android:contentDescription="" />
                        <ImageView android:id="@+id/star2" android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_off" android:contentDescription="" />
                        <ImageView android:id="@+id/star3" android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_off" android:contentDescription="" />
                        <ImageView android:id="@+id/star4" android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_off" android:contentDescription="" />
                        <ImageView android:id="@+id/star5" android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_off" android:contentDescription="" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <!-- "当前路径" label makes the strategy explicit so
                         the user understands what the chip below means. -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/network_current_path_label"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvNetworkStrategy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Relay"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvNetworkUpgrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/accent"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />

                    <!-- Backend path chip removed in v1.5.3: it
                         duplicated the tvNetworkStrategy text on the
                         left, both showing "局域网/远程" from
                         BaseUrlResolver. Now tvNetworkStrategy carries
                         the path label alone, and the backend's own
                         strategy (P2P/Relay/IPv6) is shown in the
                         network detail page to avoid the contradictory
                         "P2P + 局域网" pair the user reported. -->
                    <LinearLayout
                        android:id="@+id/pathChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:visibility="gone"
                        android:background="@drawable/bg_status_pill"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">

                        <View
                            android:id="@+id/pathDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/circle_offline" />

                        <TextView
                            android:id="@+id/tvPath"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="5dp"
                            android:text="--" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/dotIPv6"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/circle_offline" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IPv6"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/dotP2P"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/circle_offline" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="P2P"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/dotRelay"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/circle_offline" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Relay"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Recent alerts section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recent_alerts"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewAllAlerts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textSize="11sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvAlertsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_alerts"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
