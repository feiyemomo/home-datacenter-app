<?xml version="1.0" encoding="utf-8"?>
<!-- v1.6.12: Custom update-available dialog layout. Replaces the
     bare AlertDialog.Builder.setMessage() which was "too ugly" per
     user feedback. This layout shows:
       - Version transition (current → new) as a visual pill row
       - APK size with download icon
       - Scrollable release notes section (版本特点)
       - Cancel + Download-and-install buttons
     Uses bg_card_rounded (adapts to dark mode) and the warm peach
     primary color for the version pill to match the app's "液态玻璃，
     温馨" identity. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="20dp">

    <!-- Title row: icon + "发现新版本" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_refresh"
            android:layout_marginEnd="10dp"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_available_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Version transition pill: "当前 1.6.11 → 新版 1.6.12" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_status_pill"
        android:padding="10dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/update_current_version_label"
                android:textSize="10sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/tvCurrentVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="-90"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:tint="@color/text_hint" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/update_new_version_label"
                android:textSize="10sp"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/tvNewVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- APK size row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_size_label"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvUpdateSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Release notes section (版本特点) — only shown when non-empty -->
    <TextView
        android:id="@+id/tvReleaseNotesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/update_release_notes_label"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="6dp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/scrollReleaseNotes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_glass_card"
        android:padding="10dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvReleaseNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="3dp" />
    </ScrollView>

    <!-- Download progress bar (hidden until download starts) -->
    <ProgressBar
        android:id="@+id/progressDownload"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        android:max="100"
        android:progressTint="@color/primary" />

    <TextView
        android:id="@+id/tvProgressPercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Button row: Cancel + Download-and-install -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadInstall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_download_install"
            app:icon="@drawable/ic_refresh"
            app:iconTint="@color/white" />
    </LinearLayout>
</LinearLayout>
