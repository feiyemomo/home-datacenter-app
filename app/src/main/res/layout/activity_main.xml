<?xml version="1.0" encoding="utf-8"?>
<!-- v1.5.4: fitsSystemWindows on root so all fragments (Dashboard,
     Cameras, Alerts, Devices, Settings) start below the status bar
     instead of being clipped under the clock/battery/icons. The
     BottomNavContainer is constrained to the bottom so it's unaffected.
     v1.6.8: bottom nav container now reads @dimen/bottom_nav_max_width
     so wide screens (600dp+) cap the bar to a centered capsule
     instead of stretching edge-to-edge. On phones the dimen is 0dp,
     which ConstraintLayout treats as "no max" (full width). -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_gradient">

    <FrameLayout
        android:id="@+id/nav_host_fragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Floating capsule navigation bar.
         Inset 16dp from left/right and 12dp from bottom + 8dp top
         gap so the bar floats above the content and casts a soft
         shadow (provided by the layer-list drawable).
         v1.6.8: app:layout_constraintWidth_max + centered
         constraints keep the bar a centered capsule on wide
         screens. On phones bottom_nav_max_width=0dp so the bar
         spans the full width minus 16dp insets as before. -->
    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_nav_container"
        android:elevation="8dp"
        app:layout_constraintWidth_max="@dimen/bottom_nav_max_width"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@android:color/transparent"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            app:itemTextAppearanceActive="@style/BottomNavTextActive"
            app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
            app:itemActiveIndicatorStyle="@style/BottomNavActiveIndicator"
            app:itemRippleColor="@android:color/transparent"
            app:elevation="0dp"
            app:menu="@menu/bottom_nav_menu" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
