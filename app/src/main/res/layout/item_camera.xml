<?xml version="1.0" encoding="utf-8"?>
<!--
    Camera list item (v1.5.2 redesign).

    The card is now compact: a small 16:9 thumbnail on the left, the
    camera name + status on the right, and a chevron hinting that the
    row is tappable. Tapping anywhere on the row opens
    CameraDetailActivity, which is where the live video player,
    recordings dialog, alerts dialog, and PTZ controls now live.

    The previous design embedded a full-width StyledPlayerView +
    inline playback controls directly in the list item, which made
    each card ~210dp tall and forced the user to scroll a lot. The
    new design fits 4-5 cameras in the same vertical space, and the
    detail page handles playback with the same surface-before-prepare
    ExoPlayer setup that the inline path used (so the no-surface
    MediaCodec bug stays fixed — see the comment that was previously
    in this file, now in CameraDetailActivity).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!--
        StyledPlayerView kept here (visibility=gone) for two reasons:
        1. The view binding (ItemCameraBinding.playerView) still
           references it; removing the field would require touching
           every call site in CameraAdapter. Cheap to keep.
        2. If a future iteration wants to restore inline playback
           on a specific card (e.g. a long-press preview), the
           surface-before-prepare pattern needs this view to exist
           at ViewHolder creation time. Removing it would force a
           rewrite of the playback path.
    -->
    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone"
        app:resize_mode="zoom"
        app:show_buffering="when_playing"
        app:show_timeout="0"
        app:use_controller="true" />

</FrameLayout>
