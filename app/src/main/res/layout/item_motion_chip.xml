<?xml version="1.0" encoding="utf-8"?>
<!--
    v1.6.3: a single motion-event chip in the horizontal scroller.
    Layout: time (HH:MM:SS) + bullet + duration (e.g. "30s") on one
    row, pill background. Tapping the chip seeks ExoPlayer to the
    range's start. Color encodes motion_score:
      - High-score (top 25%):  bright orange #FF7043 (warm = "lots of motion")
      - Mid-score (25-75%):   amber #FFB300
      - Low-score (bottom 25%): teal #4DB6AC (cool = "minor motion")
      - PeakObjects > 0:      red #EF5350 (AI detected person/car)
    The color-coding helps the user skim a busy day: red chips are
    the most important (something was detected), orange chips are
    "lots of motion" (likely the user themselves walking by), teal
    chips are minor (leaves blowing, light changes).
-->
<TextView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tvChipLabel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:textSize="11sp"
    android:textStyle="bold"
    android:textColor="@android:color/white"
    android:fontFamily="monospace"
    android:background="@drawable/bg_chip_motion_mid"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground" />
