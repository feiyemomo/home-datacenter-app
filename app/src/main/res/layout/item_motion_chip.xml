<?xml version="1.0" encoding="utf-8"?>
<!--
    v1.6.3: a single motion-event chip in the horizontal scroller.
    v1.6.4 rev3: tightened padding + smaller text so chips don't
    visually merge into each other when fit-to-screen. Previously
    "HH:MM:SS · Ns" at 11sp with 10dp/5dp padding made a busy day's
    100+ chips overlap into a solid color block. Now shows just
    "HH:MM" (seconds + duration were noise when skimming a day) at
    9sp with 4dp/2dp padding + tighter 1dp horizontal margin.

    Color encodes motion_score:
      - High-score (top 25%):  bright orange #FF7043 (warm = "lots of motion")
      - Mid-score (25-75%):   amber #FFB300
      - Low-score (bottom 25%): teal #4DB6AC (cool = "minor motion")
      - PeakObjects > 0:      red #EF5350 (AI detected person/car)
-->
<TextView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tvChipLabel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp"
    android:layout_marginStart="1dp"
    android:layout_marginEnd="1dp"
    android:textSize="9sp"
    android:textStyle="bold"
    android:textColor="@android:color/white"
    android:fontFamily="monospace"
    android:background="@drawable/bg_chip_motion_mid"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground" />
