<?xml version="1.0" encoding="utf-8"?>
<!--
    Stat card item for the dashboard grid (Devices, MQTT, WS Clients,
    Uptime). v1.5.3: enforced a fixed 120dp height so all 4 cards in
    the 2x2 grid align perfectly regardless of label/value length —
    previously wrap_content heights led to visibly uneven rows when
    "30天 5小时" uptime overflowed while "12" device count stayed
    short. Fixed height + maxLines + ellipsize on every text field
    keeps the grid visually stable.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_glass_card">

        <!-- Top row: icon (left) + status dot (right). Fixed height
             so the icon row is vertically aligned across all 4 cards. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="fitCenter"
                android:background="@drawable/bg_icon_circle"
                android:padding="6dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Real-time status dot driven by WebSocket events -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_offline"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Value: fixed text size + maxLines=1 + ellipsize so long
             uptime strings don't break the grid alignment. -->
        <TextView
            android:id="@+id/tvValue"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom|start"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>
</FrameLayout>
