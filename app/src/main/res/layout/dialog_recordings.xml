<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <!-- v1.5.10: "Play full day" button embedded in the toolbar.
             Clicking opens a DatePickerDialog; the selected day is
             then played as one big ExoPlayer playlist (1440 60s
             clips) so the user can scrub through 24h of footage as
             a single video. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="播放整天"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无录像"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:visibility="gone">

            <com.google.android.exoplayer2.ui.StyledPlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="true"
                app:show_buffering="when_playing"
                app:resize_mode="fit"
                app:show_timeout="0" />

            <!-- Standalone playback speed button. v1.5.3: moved out
                 of the player's settings (gear) menu — the user wanted
                 speed control exposed directly. Tapping opens a popup
                 with 0.5x / 1x / 1.5x / 2x options. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaybackSpeed"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="1x"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Standalone fullscreen overlay button. ExoPlayer 2.x's
                 built-in controller fullscreen button exists but is hidden
                 by default; rather than override the controller layout
                 we provide our own overlay so the same button works in
                 all player hosts (RecordingsDialog, AlertsDialog, and
                 CameraDetailActivity's WebRTC mode). -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFullscreen"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:background="#80000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"
                android:visibility="gone"
                app:icon="@drawable/ic_fullscreen"
                app:iconTint="@android:color/white" />

            <ProgressBar
                android:id="@+id/progressPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="返回列表"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                app:cornerRadius="8dp" />

        </FrameLayout>

    </FrameLayout>

</LinearLayout>