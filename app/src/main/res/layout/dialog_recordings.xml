<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <!-- v1.5.10: "Play full day" button embedded in the toolbar.
             Clicking opens a DatePickerDialog; the selected day is
             then played as one big ExoPlayer playlist (1440 60s
             clips) so the user can scrub through 24h of footage as
             a single video. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="播放整天"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无录像"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:visibility="gone">

            <!-- v1.6.4: vertical layout — player on top (fixed 200dp
                 height in non-fullscreen), fisheye chip scroller in
                 the middle (fills remaining space), scrub bar at the
                 bottom. The user explicitly asked: "正常未全屏时，
                 播放器就放在顶部，然后中部放chip，其他插件你合理
                 布局即可".

                 In fullscreen, PlayerFullscreenHelper resizes
                 playerView to MATCH_PARENT and hides motionChipScroller
                 + dayScrubBarContainer + btnBack via hideOnFullscreen.
                 Tapping the playerView toggles these back on/off (the
                 "全屏时点击播放器收起进度条等的插件，再次点击是在
                 展现" behavior wired in PlayerFullscreenHelper). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Top: player view. v1.6.4: fixed 200dp height in
                     non-fullscreen so the chip scroller has room
                     below. In fullscreen, PlayerFullscreenHelper
                     applies MATCH_PARENT to fill the screen.

                     Wrapped in a FrameLayout so the floating overlay
                     buttons (speed, fullscreen, progress) can sit on
                     top of the player without overlapping the chip
                     scroller below. -->
                <FrameLayout
                    android:id="@+id/playerHostFrame"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@android:color/black">

                    <com.google.android.exoplayer2.ui.StyledPlayerView
                        android:id="@+id/playerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:use_controller="true"
                        app:show_buffering="when_playing"
                        app:resize_mode="fit"
                        app:show_timeout="3000" />

                    <ProgressBar
                        android:id="@+id/progressPlayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@android:color/white" />

                    <!-- Standalone playback speed button. v1.5.3: moved out
                         of the player's settings (gear) menu — the user wanted
                         speed control exposed directly. Tapping opens a popup
                         with 0.5x / 1x / 1.5x / 2x options. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlaybackSpeed"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:text="1x"
                        android:textColor="@android:color/white"
                        android:background="#80000000"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Standalone fullscreen overlay button. ExoPlayer 2.x's
                         built-in controller fullscreen button exists but is hidden
                         by default; rather than override the controller layout
                         we provide our own overlay so the same button works in
                         all player hosts (RecordingsDialog, AlertsDialog, and
                         CameraDetailActivity's WebRTC mode).

                         v1.6.4: stacked under btnPlaybackSpeed in top|end
                         (marginTop 54dp) so the two buttons don't overlap. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFullscreen"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="54dp"
                        android:layout_marginEnd="6dp"
                        android:background="#80000000"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="8dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_fullscreen"
                        app:iconTint="@android:color/white" />

                    <!-- v1.6.4: "返回列表" inside the player host frame
                         at bottom|center_horizontal. Kept on the player's
                         own surface so it stays reachable in both
                         non-fullscreen (200dp player) and fullscreen
                         (toggled by PlayerFullscreenHelper's controller
                         visibility sync). -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="返回列表"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="6dp"
                        android:background="#80000000"
                        android:textColor="@android:color/white"
                        app:cornerRadius="8dp" />
                </FrameLayout>

                <!-- Middle: fisheye chip scroller. v1.6.4: replaced the
                     v1.6.3 HorizontalScrollView with [FisheyeChipScroller]
                     which applies a scale transform to chips based on
                     their distance from the viewport center. The user
                     asked: "越靠近两边的chip越小，靠近中间的类似于
                     原有的chip，整个chip在滑动中不断变化". Chips in the
                     center stay at scale 1.0 (same as v1.6.3), chips
                     near the edges shrink to 0.55 scale + 0.5 alpha
                     for a clear focal point.

                     layout_weight=1 so it fills the remaining space
                     between the player (200dp top) and the scrub bar
                     (wrap_content bottom). Each chip is added to
                     motionChipContainer by [populateMotionChips]. -->
                <com.homedatacenter.app.ui.cameras.FisheyeChipScroller
                    android:id="@+id/motionChipScroller"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none"
                    android:background="#22000000"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/motionChipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />
                </com.homedatacenter.app.ui.cameras.FisheyeChipScroller>

                <!-- Bottom: scrub bar + overlay. v1.6.4: moved out of
                     the player's FrameLayout so it doesn't overlap the
                     player surface (was floating at the bottom of
                     videoContainer in v1.6.3). Now it sits in its own
                     row below the chip scroller, full width.

                     FrameLayout wraps SeekBar + AlertRangeOverlay so
                     the red marks sit ON TOP of the SeekBar track
                     (v1.5.14 trick). -->
                <LinearLayout
                    android:id="@+id/dayScrubBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#CC000000"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvDayPosition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDayDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <SeekBar
                            android:id="@+id/daySeekBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxHeight="4dp"
                            android:progressTint="@android:color/white"
                            android:progressBackgroundTint="#66FFFFFF"
                            android:thumbTint="@android:color/white" />

                        <com.homedatacenter.app.ui.cameras.AlertRangeOverlay
                            android:id="@+id/alertOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:layout_gravity="top"
                            android:layout_marginTop="6dp"
                            android:visibility="visible" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

</LinearLayout>
