<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <!-- v1.5.10: "Play full day" button embedded in the toolbar.
             Clicking opens a DatePickerDialog; the selected day is
             then played as one big ExoPlayer playlist (1440 60s
             clips) so the user can scrub through 24h of footage as
             a single video. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="播放整天"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无录像"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:visibility="gone">

            <com.google.android.exoplayer2.ui.StyledPlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="true"
                app:show_buffering="when_playing"
                app:resize_mode="fit"
                app:show_timeout="0" />

            <!-- v1.5.11: Big scrub bar for full-day playback. Hidden
                 by default; shown only when playDayAsPlaylist() is
                 active. Spans the full width at the bottom of the
                 video container, above the back button. Shows the
                 current wall-clock position within the 24h window
                 and lets the user drag to jump to any minute.

                 The built-in ExoPlayer controller's progress bar
                 only reflects the CURRENT 60s clip — it can't
                 span across the 1440-item playlist. We provide a
                 separate SeekBar whose max = 24*60*60*1000 ms and
                 whose progress = (currentWindowIndex * 60000) +
                 player.currentPosition. Seeking sets ExoPlayer to
                 the matching window + position via
                 player.seekTo(windowIndex, positionMs). -->
            <LinearLayout
                android:id="@+id/dayScrubBarContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:background="#CC000000"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvDayPosition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvDayDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24:00:00"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- v1.6.3: horizontal motion-chip scroller. Each chip
                     shows "HH:MM:SS · Ns" for one motion range; tapping
                     seeks ExoPlayer to that range's start. Replaces the
                     v1.6.0-v1.6.2 "drag SeekBar and hope to hit a red
                     mark" UX — chips are big enough to tap reliably
                     (~32dp tall) and labeled with the exact time so
                     the user doesn't have to read the pixel-thin red
                     bar. Populated by [RecordingsDialog.populateMotionChips]
                     from the same motion-ranges response that feeds
                     AlertRangeOverlay. Hidden when there are no
                     motion ranges (e.g. empty day or fetch failed). -->
                <HorizontalScrollView
                    android:id="@+id/motionChipScroller"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/motionChipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp" />
                </HorizontalScrollView>

                <!-- v1.5.12: alert range overlay. Paints a red bar
                     at the time positions where alerts occurred
                     during the day being played. v1.5.14: wrapped
                     SeekBar + overlay in a FrameLayout so the red
                     segments sit ON TOP of the SeekBar's progress
                     track (previously the overlay was a sibling
                     below the SeekBar, making the red bar appear
                     in a separate 6dp row that was easy to miss).
                     The overlay does not intercept touches —
                     dragging the SeekBar through an alert region
                     still works. Populated by
                     [RecordingsDialog.loadAlertRangesForDay]
                     -> [AlertRangeOverlay.setAlertRanges]. -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <SeekBar
                        android:id="@+id/daySeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="4dp"
                        android:progressTint="@android:color/white"
                        android:progressBackgroundTint="#66FFFFFF"
                        android:thumbTint="@android:color/white" />

                    <com.homedatacenter.app.ui.cameras.AlertRangeOverlay
                        android:id="@+id/alertOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_gravity="top"
                        android:layout_marginTop="6dp"
                        android:visibility="visible" />
                </FrameLayout>
            </LinearLayout>

            <!-- Standalone playback speed button. v1.5.3: moved out
                 of the player's settings (gear) menu — the user wanted
                 speed control exposed directly. Tapping opens a popup
                 with 0.5x / 1x / 1.5x / 2x options. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaybackSpeed"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="1x"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Standalone fullscreen overlay button. ExoPlayer 2.x's
                 built-in controller fullscreen button exists but is hidden
                 by default; rather than override the controller layout
                 we provide our own overlay so the same button works in
                 all player hosts (RecordingsDialog, AlertsDialog, and
                 CameraDetailActivity's WebRTC mode). -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFullscreen"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:background="#80000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"
                android:visibility="gone"
                app:icon="@drawable/ic_fullscreen"
                app:iconTint="@android:color/white" />

            <ProgressBar
                android:id="@+id/progressPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="返回列表"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="16dp"
                app:cornerRadius="8dp" />

        </FrameLayout>

    </FrameLayout>

</LinearLayout>