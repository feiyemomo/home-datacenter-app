<?xml version="1.0" encoding="utf-8"?>
<!-- v1.6.4 rev6: liquid glass (warm) background per user design
     constraint "ж¶ІжЂЃзЋ»з’ѓпјЊжё©й¦Ё". The root LinearLayout uses
     @drawable/bg_liquid_glass_warm (warm creamв†’soft blue gradient
     with a frosted-white overlay). Overlays inside videoContainer
     (toolbar over player, scrub bar, chip scroller) use
     @drawable/bg_glass_dark_panel вЂ” a translucent dark glass panel
     that floats over the black video surface. The day-list view
     (RecyclerView) shows the warm gradient directly, since the
     list cards are themselves warm glass tiles. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_liquid_glass_warm">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_glass_dark_panel"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="ж’­ж”ѕж•ґе¤©"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="16dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- v1.6.8: enhanced empty state вЂ” replaces the bare "жљ‚ж— еЅ•еѓЏ"
             TextView with a centered icon + 2-line message stack so
             the user gets visual feedback even when the list is empty.
             The icon sits inside a soft peach-tinted circle (primary
             color at 12% alpha) to add visual depth without
             overpowering the warm gradient background. The secondary
             line gives a hint about what to do next. -->
        <LinearLayout
            android:id="@+id/emptyStateContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <!-- Soft circular halo behind the icon вЂ” primary peach
                 at 18% alpha over the warm gradient gives a "spotlight"
                 feel that draws the eye to the icon. -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_icon_circle"
                    android:alpha="0.18" />

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_video"
                    android:alpha="0.85"
                    android:contentDescription="no recordings"
                    app:tint="@color/primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="жљ‚ж— еЅ•еѓЏ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvEmptyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="иЇ·зЁЌеђЋе†ЌиЇ•ж€–жЈЂжџҐж‘„еѓЏе¤ґзЉ¶жЂЃ"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone">

            <!-- v1.6.4 rev2: vertical layout re-ordered per user request
                 "е°†иї›еє¦жќЎдёЉз§»и‡іж’­ж”ѕе™Ёдё‹йќўпјЊ'иї”е›ће€—иЎЁ'жЊ‰й’®дё‹з§»":
                   1. Player (200dp, top)
                   2. Scrub bar (was at bottom вЂ” moved UP to right under player)
                   3. Fisheye chip scroller (middle, layout_weight=1)
                   4. "иї”е›ће€—иЎЁ" button (was inside player host вЂ” moved DOWN to bottom)

                 In fullscreen, PlayerFullscreenHelper resizes playerView
                 + playerHostFrame to MATCH_PARENT and hides toolbar via
                 hideOnFullscreen; dayScrubBarContainer / motionChipScroller
                 / btnBack / btnPlaybackSpeed toggle visibility via
                 controllerSyncViews on playerView tap. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Top: player host frame. Fixed 200dp in non-fullscreen;
                     MATCH_PARENT in fullscreen (PlayerFullscreenHelper's
                     secondaryPlayerView expands this). -->
                <FrameLayout
                    android:id="@+id/playerHostFrame"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@android:color/black">

                    <com.google.android.exoplayer2.ui.StyledPlayerView
                        android:id="@+id/playerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:use_controller="true"
                        app:show_buffering="when_playing"
                        app:resize_mode="fit"
                        app:show_timeout="3000" />

                    <ProgressBar
                        android:id="@+id/progressPlayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@android:color/white" />

                    <!-- v1.6.4 rev6: centered pause/play toggle button.
                         User asked: "дёєж’­ж”ѕе™Ёе¤љи®ѕи®ЎдёЂдє›дє¤дє’пј€жљ‚еЃњй”®вЂ¦)".
                         We place a 56dp circular glass button at the
                         center of the player surface. Tapping it toggles
                         ExoPlayer.play/pause. The icon is swapped at
                         runtime by PlayerGestureHelper based on the
                         player's STATE_READY + playWhenReady state.
                         Auto-hides after 2s of inactivity (handled in
                         PlayerGestureHelper) so it doesn't permanently
                         obscure the video. The dark glass background
                         matches the toolbar/scrub bar panels. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCenterPause"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_glass_dark_panel"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="32dp"
                        app:icon="@drawable/ic_pause"
                        app:iconTint="@android:color/white"
                        android:visibility="gone" />

                    <!-- Standalone playback speed button kept (hidden)
                         for backward-compat with PlayerFullscreenHelper's
                         attachSpeedButton вЂ” the slider (now inside
                         dayScrubBarContainer) is the primary speed control. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlaybackSpeed"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:text="1x"
                        android:textColor="@android:color/white"
                        android:background="#80000000"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- v1.6.5 rev7: double-tap seek animation overlays.
                         User said "еЏЊе‡»еї«йЂЂиї›ж”№дёєдё¤дёЄеЌ•д№¦еђЌеЏ·ж ·ејЏй—ЄзѓЃ
                         дё¤дё‹зљ„еЉЁз”»еђ§". Two TextViews (left-aligned and
                         right-aligned) hold "гЂЉ" and "гЂ‹" respectively,
                         initially GONE. PlayerGestureHelper shows + blinks
                         them twice (alpha 0в†’1в†’0в†’1в†’0 over ~500ms) when the
                         user double-taps the corresponding side. The "гЂЉ"
                         overlay sits on the LEFT 25% of the player surface;
                         "гЂ‹" sits on the RIGHT 25%. Centered pause button
                         isn't affected. -->
                    <TextView
                        android:id="@+id/tvSeekRewindHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="40dp"
                        android:text="гЂЉ"
                        android:textColor="@android:color/white"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowRadius="6"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:alpha="0.0"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvSeekForwardHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="40dp"
                        android:text="гЂ‹"
                        android:textColor="@android:color/white"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowRadius="6"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:alpha="0.0"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                    <!-- Fullscreen button at bottom|end (player's
                         bottom-right corner). v1.6.4 rev3: moved from
                         top|end (stacked under btnPlaybackSpeed) to
                         bottom|end per user request "е…Ёе±ЏжЊ‰й’®ж”ѕе€°ж’­ж”ѕе™Ё
                         еЏідё‹и§’". The bottom-right placement is the
                         conventional video player fullscreen button
                         location (matches YouTube, Bilibili, etc.) so
                         the user's muscle memory carries over.
                         v1.6.4 rev4: moved closer to corner (margin 6dp
                         -> 2dp) and enlarged (iconSize 24dp -> 36dp,
                         padding 8dp -> 12dp) per user request "е…Ёе±Џе›ѕж ‡
                         ењЁйќ иї‘еЏідё‹дёЂдє›пјЊе№¶ж”ѕе¤§дёЂз‚№".
                         v1.6.4 rev5: margin 2dp -> 0dp to touch the
                         corner exactly per user "е…Ёе±ЏжЊ‰й’®е†Ќйќ еЏідё‹".
                         Background removed for cleaner look вЂ” the icon
                         on black video surface is already high contrast. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFullscreen"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="0dp"
                        android:layout_marginBottom="0dp"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="14dp"
                        app:iconSize="40dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_fullscreen"
                        app:iconTint="@android:color/white" />
                </FrameLayout>

                <!-- v1.6.4 rev2: scrub bar moved UP to sit directly
                     under the player. Was at the very bottom in v1.6.3,
                     which forced the user to reach past the chip
                     scroller to drag the SeekBar. Now SeekBar + overlay
                     sit immediately below the player surface вЂ” natural
                     thumb-reach when the player is at eye level.

                     v1.6.9: panel now uses @drawable/bg_glass_dark_panel
                     as its background. Previously it was transparent,
                     which meant the white time labels (tvDayPosition /
                     tvDayDuration) sat directly on the warm creamв†’soft
                     blue gradient root background вЂ” the user reported
                     "иї›еє¦жќЎзљ„ж—¶й—ґдёЋиѓЊж™Їзљ„еЇ№жЇ”еє¦еѕ€дЅЋпјЊзњ‹дёЌжё…". Wrapping
                     the whole panel in dark glass gives the white text
                     a high-contrast backdrop and visually groups the
                     time labels + SeekBar + speed slider as one
                     "control deck" under the player.

                     AlertRangeOverlay + SeekBar share a FrameLayout so
                     the red marks sit on top of the SeekBar track.
                     The speed slider lives below the SeekBar so the
                     user's thumb naturally travels from "position the
                     playhead" to "tweak playback speed" вЂ” both are
                     timeline-style controls and belong together. -->
                <LinearLayout
                    android:id="@+id/dayScrubBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_dark_panel"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvDayPosition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:shadowColor="#000000"
                            android:shadowRadius="2"
                            android:shadowDx="0"
                            android:shadowDy="1" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDayDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:shadowColor="#000000"
                            android:shadowRadius="2"
                            android:shadowDx="0"
                            android:shadowDy="1" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <SeekBar
                            android:id="@+id/daySeekBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxHeight="8dp"
                            android:progressTint="#FF8A65"
                            android:progressBackgroundTint="#992D3748"
                            android:thumbTint="#FF8A65"
                            android:splitTrack="false" />

                        <com.homedatacenter.app.ui.cameras.AlertRangeOverlay
                            android:id="@+id/alertOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:layout_gravity="top"
                            android:layout_marginTop="4dp"
                            android:visibility="visible" />
                    </FrameLayout>

                    <!-- v1.6.9: speed slider moved here from the top of
                         the player surface. User said "еЂЌйЂџи·іеЏЇд»ҐжЊЄе€°
                         дё‹йќўеђ€йЂ‚зљ„дЅЌзЅ®". Sitting directly under the
                         SeekBar lets the user's thumb flow from
                         "scrub position" to "tweak speed" вЂ” both are
                         timeline-style horizontal controls. The slider
                         spans the full panel width (was 220dp centered)
                         for a more comfortable touch target, and the
                         label sits at the end so the user sees the
                         current value without obscuring the thumb.
                         Label + track use white on the dark glass
                         panel for high contrast. -->
                    <LinearLayout
                        android:id="@+id/speedBarContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="еЂЌйЂџ"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"
                            android:alpha="0.85" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/speedSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0.5"
                            android:valueTo="5.0"
                            android:stepSize="0.5"
                            android:value="1.0"
                            app:thumbColor="@android:color/white"
                            app:trackColorActive="@android:color/white"
                            app:trackColorInactive="#80FFFFFF"
                            app:haloColor="#40FFFFFF" />

                        <TextView
                            android:id="@+id/tvSpeedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1x"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:minWidth="38dp"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Middle: fisheye chip container. v1.6.4 rev5: returned
                     to HorizontalScrollView (rev4 was non-scrolling ViewGroup).
                     The user said "иї™дёЄchipж»‘еЉЁдёЌдє†пјЊж€‘жѓіи¦Ѓж»‘еЉЁзљ„ж—¶еЂ™пјЊ
                     дё­й—ґе¤§зљ„chipи·џзќЂж›їжЌў". Chips scroll horizontally; the
                     one in the viewport center is scaled to full size with
                     its "HH:mm" label visible; chips scrolling toward the
                     edges shrink and collapse to thin colored bars (no text).

                     layout_weight=1 fills remaining space between the scrub
                     bar (above) and the "иї”е›ће€—иЎЁ" button (below). -->
                <com.homedatacenter.app.ui.cameras.FisheyeChipScroller
                    android:id="@+id/motionChipScroller"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="6dp"
                    android:scrollbars="none"
                    android:overScrollMode="never"
                    android:background="@android:color/transparent"
                    android:fillViewport="false"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/motionChipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />
                </com.homedatacenter.app.ui.cameras.FisheyeChipScroller>

                <!-- Bottom: "иї”е›ће€—иЎЁ" button. v1.6.4 rev2: moved DOWN
                     from inside the player host (was bottom|center_horizontal
                     of playerHostFrame) to the very bottom of the screen.
                     The user said "иї”е›ће€—иЎЁжЊ‰й’®дё‹з§»" вЂ” placing it at
                     the bottom of the layout gives it a stable, predictable
                     position regardless of player size.

                     v1.6.4 rev5: restyled per user feedback "иї”е›ће€—иЎЁжЊ‰й’®
                     еҐЅдё‘". Was OutlinedButton.Icon with 1dp 50% white stroke.
                     v1.6.6 rev8: user said "иї”е›ће€—иЎЁзљ„еЇ№жЇ”еє¦е¤ЄдЅЋдє†" вЂ” over
                     the warm cream/blue gradient background, white text +
                     thin translucent stroke was nearly invisible. Switched
                     to FILLED style with a dark translucent background
                     (#B3000000 = 70% black) + bold white text + white
                     icon. The high-contrast pill pops clearly against
                     the warm gradient. Corner radius 24dp (pill shape)
                     preserved. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.Material3.Button.Icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="иї”е›ће€—иЎЁ"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:minWidth="120dp"
                    android:backgroundTint="#B3000000"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_baseline_arrow_back_24"
                    app:iconTint="@android:color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:cornerRadius="24dp" />
            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

</LinearLayout>
