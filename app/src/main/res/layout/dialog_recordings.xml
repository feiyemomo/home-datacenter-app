<?xml version="1.0" encoding="utf-8"?>
<!-- v1.6.4 rev6: liquid glass (warm) background per user design
     constraint "液态玻璃，温馨". The root LinearLayout uses
     @drawable/bg_liquid_glass_warm (warm cream→soft blue gradient
     with a frosted-white overlay). Overlays inside videoContainer
     (toolbar over player, scrub bar, chip scroller) use
     @drawable/bg_glass_dark_panel — a translucent dark glass panel
     that floats over the black video surface. The day-list view
     (RecyclerView) shows the warm gradient directly, since the
     list cards are themselves warm glass tiles. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_liquid_glass_warm">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_glass_dark_panel"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="播放整天"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无录像"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:visibility="gone">

            <!-- v1.6.4 rev2: vertical layout re-ordered per user request
                 "将进度条上移至播放器下面，'返回列表'按钮下移":
                   1. Player (200dp, top)
                   2. Scrub bar (was at bottom — moved UP to right under player)
                   3. Fisheye chip scroller (middle, layout_weight=1)
                   4. "返回列表" button (was inside player host — moved DOWN to bottom)

                 In fullscreen, PlayerFullscreenHelper resizes playerView
                 + playerHostFrame to MATCH_PARENT and hides toolbar via
                 hideOnFullscreen; dayScrubBarContainer / motionChipScroller
                 / btnBack / btnPlaybackSpeed toggle visibility via
                 controllerSyncViews on playerView tap. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Top: player host frame. Fixed 200dp in non-fullscreen;
                     MATCH_PARENT in fullscreen (PlayerFullscreenHelper's
                     secondaryPlayerView expands this). -->
                <FrameLayout
                    android:id="@+id/playerHostFrame"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@android:color/black">

                    <com.google.android.exoplayer2.ui.StyledPlayerView
                        android:id="@+id/playerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:use_controller="true"
                        app:show_buffering="when_playing"
                        app:resize_mode="fit"
                        app:show_timeout="3000" />

                    <ProgressBar
                        android:id="@+id/progressPlayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@android:color/white" />

                    <!-- v1.6.4 rev6: centered pause/play toggle button.
                         User asked: "为播放器多设计一些交互（暂停键…)".
                         We place a 56dp circular glass button at the
                         center of the player surface. Tapping it toggles
                         ExoPlayer.play/pause. The icon is swapped at
                         runtime by PlayerGestureHelper based on the
                         player's STATE_READY + playWhenReady state.
                         Auto-hides after 2s of inactivity (handled in
                         PlayerGestureHelper) so it doesn't permanently
                         obscure the video. The dark glass background
                         matches the toolbar/scrub bar panels. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCenterPause"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_glass_dark_panel"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:iconSize="32dp"
                        app:icon="@drawable/ic_pause"
                        app:iconTint="@android:color/white"
                        android:visibility="gone" />

                    <!-- v1.6.5 rev7: playback speed is now a horizontal
                         Slider instead of a dropdown button. User said
                         "变速条改为可滑动的，最高切到5x吧". The slider
                         sits at the top-center of the playerView so it
                         doesn't overlap the bottom|end fullscreen button
                         or the centered pause button.
                         Discrete steps 0.5x..5.0x (10 steps); current
                         value is displayed in a small label to the right
                         of the slider. Slider track + thumb use white
                         for high contrast on the dark video surface. -->
                    <LinearLayout
                        android:id="@+id/speedBarContainer"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_glass_dark_panel"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:visibility="gone">

                        <com.google.android.material.slider.Slider
                            android:id="@+id/speedSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="0.5"
                            android:valueTo="5.0"
                            android:stepSize="0.5"
                            android:value="1.0"
                            app:thumbColor="@android:color/white"
                            app:trackColorActive="@android:color/white"
                            app:trackColorInactive="#80FFFFFF"
                            app:haloColor="#40FFFFFF" />

                        <TextView
                            android:id="@+id/tvSpeedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1x"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:minWidth="34dp"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Standalone playback speed button kept (hidden)
                         for backward-compat with PlayerFullscreenHelper's
                         attachSpeedButton — but the slider is the new
                         primary speed control. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlaybackSpeed"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:text="1x"
                        android:textColor="@android:color/white"
                        android:background="#80000000"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- v1.6.5 rev7: double-tap seek animation overlays.
                         User said "双击快退进改为两个单书名号样式闪烁
                         两下的动画吧". Two TextViews (left-aligned and
                         right-aligned) hold "《" and "》" respectively,
                         initially GONE. PlayerGestureHelper shows + blinks
                         them twice (alpha 0→1→0→1→0 over ~500ms) when the
                         user double-taps the corresponding side. The "《"
                         overlay sits on the LEFT 25% of the player surface;
                         "》" sits on the RIGHT 25%. Centered pause button
                         isn't affected. -->
                    <TextView
                        android:id="@+id/tvSeekRewindHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="40dp"
                        android:text="《"
                        android:textColor="@android:color/white"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowRadius="6"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:alpha="0.0"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/tvSeekForwardHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="40dp"
                        android:text="》"
                        android:textColor="@android:color/white"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowRadius="6"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:alpha="0.0"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                    <!-- Fullscreen button at bottom|end (player's
                         bottom-right corner). v1.6.4 rev3: moved from
                         top|end (stacked under btnPlaybackSpeed) to
                         bottom|end per user request "全屏按钮放到播放器
                         右下角". The bottom-right placement is the
                         conventional video player fullscreen button
                         location (matches YouTube, Bilibili, etc.) so
                         the user's muscle memory carries over.
                         v1.6.4 rev4: moved closer to corner (margin 6dp
                         -> 2dp) and enlarged (iconSize 24dp -> 36dp,
                         padding 8dp -> 12dp) per user request "全屏图标
                         在靠近右下一些，并放大一点".
                         v1.6.4 rev5: margin 2dp -> 0dp to touch the
                         corner exactly per user "全屏按钮再靠右下".
                         Background removed for cleaner look — the icon
                         on black video surface is already high contrast. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFullscreen"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="0dp"
                        android:layout_marginBottom="0dp"
                        android:background="@android:color/transparent"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="14dp"
                        app:iconSize="40dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_fullscreen"
                        app:iconTint="@android:color/white" />
                </FrameLayout>

                <!-- v1.6.4 rev2: scrub bar moved UP to sit directly
                     under the player. Was at the very bottom in v1.6.3,
                     which forced the user to reach past the chip
                     scroller to drag the SeekBar. Now SeekBar + overlay
                     sit immediately below the player surface — natural
                     thumb-reach when the player is at eye level.

                     AlertRangeOverlay + SeekBar share a FrameLayout so
                     the red marks sit on top of the SeekBar track. -->
                <LinearLayout
                    android:id="@+id/dayScrubBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvDayPosition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDayDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <SeekBar
                            android:id="@+id/daySeekBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxHeight="4dp"
                            android:progressTint="@android:color/white"
                            android:progressBackgroundTint="#66FFFFFF"
                            android:thumbTint="@android:color/white" />

                        <com.homedatacenter.app.ui.cameras.AlertRangeOverlay
                            android:id="@+id/alertOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:layout_gravity="top"
                            android:layout_marginTop="4dp"
                            android:visibility="visible" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Middle: fisheye chip container. v1.6.4 rev5: returned
                     to HorizontalScrollView (rev4 was non-scrolling ViewGroup).
                     The user said "这个chip滑动不了，我想要滑动的时候，
                     中间大的chip跟着替换". Chips scroll horizontally; the
                     one in the viewport center is scaled to full size with
                     its "HH:mm" label visible; chips scrolling toward the
                     edges shrink and collapse to thin colored bars (no text).

                     layout_weight=1 fills remaining space between the scrub
                     bar (above) and the "返回列表" button (below). -->
                <com.homedatacenter.app.ui.cameras.FisheyeChipScroller
                    android:id="@+id/motionChipScroller"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none"
                    android:overScrollMode="never"
                    android:background="@android:color/transparent"
                    android:fillViewport="false"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/motionChipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />
                </com.homedatacenter.app.ui.cameras.FisheyeChipScroller>

                <!-- Bottom: "返回列表" button. v1.6.4 rev2: moved DOWN
                     from inside the player host (was bottom|center_horizontal
                     of playerHostFrame) to the very bottom of the screen.
                     The user said "返回列表按钮下移" — placing it at
                     the bottom of the layout gives it a stable, predictable
                     position regardless of player size.

                     v1.6.4 rev5: restyled per user feedback "返回列表按钮
                     好丑". Was OutlinedButton.Icon with 1dp 50% white stroke.
                     v1.6.6 rev8: user said "返回列表的对比度太低了" — over
                     the warm cream/blue gradient background, white text +
                     thin translucent stroke was nearly invisible. Switched
                     to FILLED style with a dark translucent background
                     (#B3000000 = 70% black) + bold white text + white
                     icon. The high-contrast pill pops clearly against
                     the warm gradient. Corner radius 24dp (pill shape)
                     preserved. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    style="@style/Widget.Material3.Button.Icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="返回列表"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:minWidth="120dp"
                    android:backgroundTint="#B3000000"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:icon="@drawable/ic_baseline_arrow_back_24"
                    app:iconTint="@android:color/white"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:cornerRadius="24dp" />
            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

</LinearLayout>
