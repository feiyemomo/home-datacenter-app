<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <!-- v1.5.10: "Play full day" button embedded in the toolbar.
             Clicking opens a DatePickerDialog; the selected day is
             then played as one big ExoPlayer playlist (1440 60s
             clips) so the user can scrub through 24h of footage as
             a single video. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="播放整天"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无录像"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:visibility="gone">

            <com.google.android.exoplayer2.ui.StyledPlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="true"
                app:show_buffering="when_playing"
                app:resize_mode="fit"
                app:show_timeout="0" />

            <!-- v1.5.11: Big scrub bar for full-day playback. Hidden
                 by default; shown only when playDayAsPlaylist() is
                 active. Spans the full width at the bottom of the
                 video container, above the back button. Shows the
                 current wall-clock position within the 24h window
                 and lets the user drag to jump to any minute.

                 The built-in ExoPlayer controller's progress bar
                 only reflects the CURRENT 60s clip — it can't
                 span across the 1440-item playlist. We provide a
                 separate SeekBar whose max = 24*60*60*1000 ms and
                 whose progress = (currentWindowIndex * 60000) +
                 player.currentPosition. Seeking sets ExoPlayer to
                 the matching window + position via
                 player.seekTo(windowIndex, positionMs). -->
            <LinearLayout
                android:id="@+id/dayScrubBarContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:background="#CC000000"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvDayPosition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvDayDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24:00:00"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- v1.6.4: interactive motion timeline. Replaces the
                     v1.6.3 HorizontalScrollView chip list (which was
                     too slow to scroll and not intuitive). Each motion
                     range is drawn at its time-proportional X position
                     across the FULL screen width, so the entire 24h is
                     visible at once — no scrolling. Natural motion
                     density (mornings + evenings active, midday quiet)
                     is immediately visible as "dense edges + sparse
                     middle", which is exactly what the user asked for.

                     Tapping a range seeks ExoPlayer to that range's
                     start via the AlertRangeOverlay.onSeekToRange
                     callback (wired in RecordingsDialog.kt).

                     Laid out in its own row ABOVE the SeekBar (v1.6.3
                     shared a FrameLayout with the SeekBar which caused
                     touch conflicts — taps on a red range would either
                     seek OR drag the SeekBar, never both). Now the
                     overlay is its own 28dp-tall row, well within the
                     recommended 48dp tap target when expanded by the
                     touch-slop hit-rect logic in findRangeAtX.

                     4-tier intensity coloring (teal/amber/orange/red)
                     replaces the v1.6.3 "regular vs AI" two-color
                     scheme — lets the user visually skim a busy day. -->
                <com.homedatacenter.app.ui.cameras.AlertRangeOverlay
                    android:id="@+id/alertOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginBottom="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="visible" />

                <!-- v1.6.4: SeekBar in its own row (no longer sharing
                     a FrameLayout with the overlay). Dragging the
                     SeekBar no longer conflicts with tapping a motion
                     range — the two gestures happen in separate rows. -->
                <SeekBar
                    android:id="@+id/daySeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="4dp"
                    android:progressTint="@android:color/white"
                    android:progressBackgroundTint="#66FFFFFF"
                    android:thumbTint="@android:color/white" />
            </LinearLayout>

            <!-- Standalone playback speed button. v1.5.3: moved out
                 of the player's settings (gear) menu — the user wanted
                 speed control exposed directly. Tapping opens a popup
                 with 0.5x / 1x / 1.5x / 2x options. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaybackSpeed"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:text="1x"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Standalone fullscreen overlay button. ExoPlayer 2.x's
                 built-in controller fullscreen button exists but is hidden
                 by default; rather than override the controller layout
                 we provide our own overlay so the same button works in
                 all player hosts (RecordingsDialog, AlertsDialog, and
                 CameraDetailActivity's WebRTC mode).

                 v1.6.4: moved from bottom|end to top|end (stacked
                 below btnPlaybackSpeed). The previous bottom|end
                 placement overlapped with the dayScrubBarContainer
                 (chips + SeekBar) at the bottom of the screen — the
                 user reported "返回列表按钮，与全屏按钮、chip这些有
                 重叠". Now both overlay buttons live in the top-right
                 corner where they don't conflict with the scrub bar. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFullscreen"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="54dp"
                android:layout_marginEnd="6dp"
                android:background="#80000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"
                android:visibility="gone"
                app:icon="@drawable/ic_fullscreen"
                app:iconTint="@android:color/white" />

            <ProgressBar
                android:id="@+id/progressPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@android:color/white" />

            <!-- v1.6.4: "返回列表" moved from bottom|center_horizontal
                 to center. The previous bottom placement overlapped
                 with the dayScrubBarContainer's SeekBar + chips — the
                 user reported "返回列表按钮，与全屏按钮、chip这些有
                 重叠，而且非全屏时，中间有一大块空白可以利用".

                 Now the button floats in the middle of the video area,
                 using the empty space the user pointed out. We add a
                 marginBottom to keep it above the dayScrubBarContainer
                 (~80dp tall) so it stays visually clear of the scrub
                 bar in portrait. In fullscreen the button is hidden
                 by PlayerFullscreenHelper's hideOnFullscreen list. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="返回列表"
                android:layout_gravity="center"
                android:layout_marginBottom="80dp"
                app:cornerRadius="8dp" />

        </FrameLayout>

    </FrameLayout>

</LinearLayout>