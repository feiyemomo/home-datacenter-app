<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_baseline_arrow_back_24"
        app:titleTextColor="@android:color/white">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayDay"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="播放整天"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:icon="@drawable/ic_video"
            app:iconTint="@android:color/white" />

    </com.google.android.material.appbar.MaterialToolbar>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无录像"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:visibility="gone">

            <!-- v1.6.4 rev2: vertical layout re-ordered per user request
                 "将进度条上移至播放器下面，'返回列表'按钮下移":
                   1. Player (200dp, top)
                   2. Scrub bar (was at bottom — moved UP to right under player)
                   3. Fisheye chip scroller (middle, layout_weight=1)
                   4. "返回列表" button (was inside player host — moved DOWN to bottom)

                 In fullscreen, PlayerFullscreenHelper resizes playerView
                 + playerHostFrame to MATCH_PARENT and hides toolbar via
                 hideOnFullscreen; dayScrubBarContainer / motionChipScroller
                 / btnBack / btnPlaybackSpeed toggle visibility via
                 controllerSyncViews on playerView tap. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Top: player host frame. Fixed 200dp in non-fullscreen;
                     MATCH_PARENT in fullscreen (PlayerFullscreenHelper's
                     secondaryPlayerView expands this). -->
                <FrameLayout
                    android:id="@+id/playerHostFrame"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@android:color/black">

                    <com.google.android.exoplayer2.ui.StyledPlayerView
                        android:id="@+id/playerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:use_controller="true"
                        app:show_buffering="when_playing"
                        app:resize_mode="fit"
                        app:show_timeout="3000" />

                    <ProgressBar
                        android:id="@+id/progressPlayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@android:color/white" />

                    <!-- Standalone playback speed button. v1.6.4 rev2:
                         menu now opens as a Material AlertDialog with
                         single-choice items + rounded corners (was
                         PopupMenu which felt "生硬"). Stays in top|end
                         so it's reachable over the player surface. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlaybackSpeed"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:text="1x"
                        android:textColor="@android:color/white"
                        android:background="#80000000"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Fullscreen button stacked under btnPlaybackSpeed. -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFullscreen"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="54dp"
                        android:layout_marginEnd="6dp"
                        android:background="#80000000"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="8dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_fullscreen"
                        app:iconTint="@android:color/white" />
                </FrameLayout>

                <!-- v1.6.4 rev2: scrub bar moved UP to sit directly
                     under the player. Was at the very bottom in v1.6.3,
                     which forced the user to reach past the chip
                     scroller to drag the SeekBar. Now SeekBar + overlay
                     sit immediately below the player surface — natural
                     thumb-reach when the player is at eye level.

                     AlertRangeOverlay + SeekBar share a FrameLayout so
                     the red marks sit on top of the SeekBar track. -->
                <LinearLayout
                    android:id="@+id/dayScrubBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#CC000000"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tvDayPosition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDayDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24:00:00"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <SeekBar
                            android:id="@+id/daySeekBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxHeight="4dp"
                            android:progressTint="@android:color/white"
                            android:progressBackgroundTint="#66FFFFFF"
                            android:thumbTint="@android:color/white" />

                        <com.homedatacenter.app.ui.cameras.AlertRangeOverlay
                            android:id="@+id/alertOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:layout_gravity="top"
                            android:layout_marginTop="6dp"
                            android:visibility="visible" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Middle: fisheye chip container. v1.6.4 rev2: now a
                     non-scrolling ViewGroup — all chips are fit into the
                     viewport width, with edge chips shrunk via scaleX/Y
                     for a compression effect (no alpha dimming, no
                     hiding). The user asked "我想要chip靠近两边时的挤压
                     效果，越靠近边上，体积越小，而不是隐藏；同时我要能
                     够看到一整天的chip那种". This container delivers
                     both — fit-to-screen + edge compression.

                     layout_weight=1 so it fills the remaining space
                     between the scrub bar (above) and the "返回列表"
                     button (below). -->
                <com.homedatacenter.app.ui.cameras.FisheyeChipScroller
                    android:id="@+id/motionChipScroller"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#1A000000"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/motionChipContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </com.homedatacenter.app.ui.cameras.FisheyeChipScroller>

                <!-- Bottom: "返回列表" button. v1.6.4 rev2: moved DOWN
                     from inside the player host (was bottom|center_horizontal
                     of playerHostFrame) to the very bottom of the screen.
                     The user said "返回列表按钮下移" — placing it at
                     the bottom of the layout gives it a stable, predictable
                     position regardless of player size.

                     Centered horizontally, with 16dp bottom margin to
                     clear gesture nav bars on edge-to-edge devices. -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="返回列表"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:background="#80000000"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

</LinearLayout>
