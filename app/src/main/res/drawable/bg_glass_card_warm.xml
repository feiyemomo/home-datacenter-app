<?xml version="1.0" encoding="utf-8"?>
<!-- v1.6.4 rev6: warm liquid glass card for the camera list.
     Replaces the previous solid dark CardBackground (#171C24)
     which felt cold. The card uses a frosted-white solid + a
     subtle 1dp warm peach border + 20dp corner radius. The warm
     tint matches the dialog's liquid glass palette so the entire
     camera flow (list → detail → recordings) shares a single
     "温馨 + 液态玻璃" identity.

     v1.6.12: use @color/glass_bg and @color/glass_border so the
     card adapts to dark mode (translucent white in light, translucent
     white-at-low-alpha in dark). Previously hardcoded #F2FFFFFF
     which stayed bright white in dark mode. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_bg" />
    <stroke
        android:width="1.2dp"
        android:color="@color/glass_border" />
    <corners android:radius="22dp" />
</shape>
