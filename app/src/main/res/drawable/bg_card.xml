<?xml version="1.0" encoding="utf-8"?>
<!-- v1.6.8: warmed up the alert/recording card background. Was
     pure white + cold gray border (#E0E0E0), which read as sterile
     next to the warm gradient background of fragment_dashboard and
     the warm glass tiles of the recordings list. Now uses warm cream
     (#FFFEFB) + soft peach border (#FFE0CC) so the card visually
     belongs to the "液态玻璃，温馨" palette while still feeling
     like a neutral surface (alerts shouldn't be overly warm since
     they represent urgent events). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#FFFEFB" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#FFE0CC" />
    <padding
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp" />
</shape>
