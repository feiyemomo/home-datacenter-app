<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- WebRTC permissions: required by WebView's RTCPeerConnection even for
         recvonly streams. Without CAMERA/MICROPHONE declared, WebView refuses
         to grant PermissionRequest on media devices and ICE never completes. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Camera and microphone are optional because the app receives streams
         and must remain installable on devices without capture hardware. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />

    <application
        android:name=".HomeCenterApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HomeDatacenter"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <activity
            android:name=".ui.cameras.CameraDetailActivity"
            android:exported="false"
            android:label="@string/camera_detail_title"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout" />

        <activity
            android:name=".ui.admin.UsersActivity"
            android:exported="false"
            android:label="@string/users_title" />

        <activity
            android:name=".ui.network.NetworkDetailActivity"
            android:exported="false"
            android:label="@string/network_detail_title" />

    </application>

</manifest>
